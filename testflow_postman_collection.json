{
	"info": {
		"_postman_id": "a1b2c3d4-e5f6-4a5b-8c9d-0e1f2a3b4c5d",
		"name": "TESTFLOW API (Production)",
		"description": "Production-ready Postman collection for the TESTFLOW Online Assessment Platform. Includes endpoints for Auth, User Management, Assessments, and Attempts.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Register",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"Password123!\",\n  \"role\": \"owner\",\n  \"institutionName\": \"Test Academy\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] }
					}
				},
				{
					"name": "Verify Email (OTP)",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"john@example.com\",\n  \"otp\": \"123456\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/auth/verify-email", "host": ["{{baseUrl}}"], "path": ["auth", "verify-email"] }
					}
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.token) {",
									"    pm.environment.set(\"accessToken\", jsonData.token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"Password123!\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
					}
				},
				{
					"name": "Resend OTP",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"john@example.com\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/auth/resend-otp", "host": ["{{baseUrl}}"], "path": ["auth", "resend-otp"] }
					}
				},
				{
					"name": "Get Profile (Me)",
					"request": {
						"method": "GET",
						"header": [],
						"url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
					}
				},
				{
					"name": "Refresh Token",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/auth/refresh", "host": ["{{baseUrl}}"], "path": ["auth", "refresh"] }
					}
				},
				{
					"name": "Logout",
					"request": {
						"method": "GET",
						"header": [],
						"url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth", "logout"] }
					}
				}
			]
		},
		{
			"name": "User Management",
			"item": [
				{
					"name": "Get Students",
					"request": {
						"method": "GET",
						"header": [],
						"url": { "raw": "{{baseUrl}}/users/students", "host": ["{{baseUrl}}"], "path": ["users", "students"] }
					}
				},
				{
					"name": "Create Student",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Student One\",\n  \"email\": \"student1@example.com\",\n  \"password\": \"Pass123\",\n  \"studentRoll\": \"ROLL001\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/users/students", "host": ["{{baseUrl}}"], "path": ["users", "students"] }
					}
				},
				{
					"name": "Get Instructors",
					"request": {
						"method": "GET",
						"header": [],
						"url": { "raw": "{{baseUrl}}/users/instructors", "host": ["{{baseUrl}}"], "path": ["users", "instructors"] }
					}
				},
				{
					"name": "Get Archived Students",
					"request": {
						"method": "GET",
						"header": [],
						"url": { "raw": "{{baseUrl}}/users/students/archived", "host": ["{{baseUrl}}"], "path": ["users", "students", "archived"] }
					}
				}
			]
		},
		{
			"name": "Assessments (Tests)",
			"item": [
				{
					"name": "Get All Tests",
					"request": {
						"method": "GET",
						"header": [],
						"url": { "raw": "{{baseUrl}}/tests", "host": ["{{baseUrl}}"], "path": ["tests"] }
					}
				},
				{
					"name": "Create Test Manual",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"Advanced Physics\",\n  \"description\": \"Final exam for semester 2\",\n  \"duration\": 90\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/tests", "host": ["{{baseUrl}}"], "path": ["tests"] }
					}
				},
				{
					"name": "Upload PDF Test",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{ "key": "pdfFile", "type": "file", "src": [] },
								{ "key": "title", "value": "History Quiz", "type": "text" },
								{ "key": "duration", "value": "30", "type": "text" }
							]
						},
						"url": { "raw": "{{baseUrl}}/tests/upload-pdf", "host": ["{{baseUrl}}"], "path": ["tests", "upload-pdf"] }
					}
				},
				{
					"name": "Get Test Details",
					"request": {
						"method": "GET",
						"header": [],
						"url": { "raw": "{{baseUrl}}/tests/:id", "host": ["{{baseUrl}}"], "path": ["tests", ":id"], "variable": [{ "key": "id", "value": "" }] }
					}
				},
				{
					"name": "Publish Test",
					"request": {
						"method": "PATCH",
						"header": [],
						"url": { "raw": "{{baseUrl}}/tests/:id/publish", "host": ["{{baseUrl}}"], "path": ["tests", ":id", "publish"], "variable": [{ "key": "id", "value": "" }] }
					}
				},
				{
					"name": "Archive Test",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": { "raw": "{{baseUrl}}/tests/:id", "host": ["{{baseUrl}}"], "path": ["tests", ":id"], "variable": [{ "key": "id", "value": "" }] }
					}
				},
				{
					"name": "Get Archived Tests",
					"request": {
						"method": "GET",
						"header": [],
						"url": { "raw": "{{baseUrl}}/tests/archived/all", "host": ["{{baseUrl}}"], "path": ["tests", "archived", "all"] }
					}
				},
				{
					"name": "Restore Test",
					"request": {
						"method": "PATCH",
						"header": [],
						"url": { "raw": "{{baseUrl}}/tests/:id/restore", "host": ["{{baseUrl}}"], "path": ["tests", ":id", "restore"], "variable": [{ "key": "id", "value": "" }] }
					}
				},
				{
					"name": "Leaderboard",
					"request": {
						"method": "GET",
						"header": [],
						"url": { "raw": "{{baseUrl}}/tests/leaderboard", "host": ["{{baseUrl}}"], "path": ["tests", "leaderboard"] }
					}
				}
			]
		},
		{
			"name": "Attempts",
			"item": [
				{
					"name": "Start Attempt",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"testId\": \"TEST_ID_HERE\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/attempts/start", "host": ["{{baseUrl}}"], "path": ["attempts", "start"] }
					}
				},
				{
					"name": "Save Answer",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"attemptId\": \"ATTEMPT_ID_HERE\",\n  \"questionId\": \"QUESTION_ID_HERE\",\n  \"selectedOption\": \"A\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/attempts/save-answer", "host": ["{{baseUrl}}"], "path": ["attempts", "save-answer"] }
					}
				},
				{
					"name": "Submit Attempt",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"attemptId\": \"ATTEMPT_ID_HERE\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/attempts/submit", "host": ["{{baseUrl}}"], "path": ["attempts", "submit"] }
					}
				},
				{
					"name": "Get My Attempts",
					"request": {
						"method": "GET",
						"header": [],
						"url": { "raw": "{{baseUrl}}/attempts/me", "host": ["{{baseUrl}}"], "path": ["attempts", "me"] }
					}
				}
			]
		},
		{
			"name": "Answer Keys",
			"item": [
				{
					"name": "Get Keys",
					"request": {
						"method": "GET",
						"header": [],
						"url": { "raw": "{{baseUrl}}/answer-keys", "host": ["{{baseUrl}}"], "path": ["answer-keys"] }
					}
				},
				{
					"name": "Upload Key",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{ "key": "pdfFile", "type": "file", "src": [] },
								{ "key": "title", "value": "Physics Key", "type": "text" }
							]
						},
						"url": { "raw": "{{baseUrl}}/answer-keys", "host": ["{{baseUrl}}"], "path": ["answer-keys"] }
					}
				}
			]
		}
	],
	"auth": {
		"type": "bearer",
		"bearer": [
			{ "key": "token", "value": "{{accessToken}}", "type": "string" }
		]
	},
	"variable": [
		{ "key": "baseUrl", "value": "https://testflow-api.duckdns.org/api", "type": "string" },
		{ "key": "accessToken", "value": "", "type": "string" },
		{ "key": "refreshToken", "value": "", "type": "string" }
	]
}
